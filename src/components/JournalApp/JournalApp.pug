style.
  .hidden { display: none; }

main.app
  #error.hidden(role="alert" aria-live="assertive")
    | {{error}}
  #loading(role="status" aria-live="polite" aria-label="{{loadingAriaLabel}}") {{loadingText}}
  #content.hidden
    header
      .heading
        img(src="/src/images/logo.svg", alt="{{logoAlt}}")
        h1 {{appTitle}}
      .settings
        .date-picker-bar(role="group" aria-label="{{dateNavAriaLabel}}")
          button#prev-day.btn.btn-icon(data-action="click:prevDay" aria-label="{{prevDayAriaLabel}}") <
          button#next-day.btn.btn-icon(data-action="click:nextDay" aria-label="{{nextDayAriaLabel}}") >
          label(for="date-picker") {{dateLabel}}
          input#date-picker(type="date" data-action="change:onDateChange" aria-label="{{selectDateAriaLabel}}")
        button#settings-btn.btn(data-action="click:openSettings" aria-label="{{openSettingsAriaLabel}}") {{settingsLabel}}
    dialog#settings(aria-labelledby="settings-title")
      h2#settings-title {{settingsLabel}}
        button.btn.btn-icon(data-action="click:closeSettings" aria-label="{{closeSettingsAriaLabel}}") ╳
      .setting
        label(for="setting-growth-area") {{growthAreaLabel}}
        select#setting-growth-area(
          data-action="change:onSettingChange"
          name="growthArea"
          aria-label="{{selectGrowthAreaAriaLabel}}"
        )
    journal-day#day