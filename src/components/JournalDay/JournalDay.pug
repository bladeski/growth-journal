section.day(aria-label="Journal entry for {{date}}")
  header.day-header
    h2.day-title {{date}}
    .value-challenge(role="group" aria-label="Today's focus")
      span.value-label(aria-label="Value") Value: {{valueChallenge.value}}
      span.challenge-label(aria-label="Challenge") Challenge: {{valueChallenge.challenge}}
  .grid
    .questions(role="region" aria-label="Daily reflection questions")
      journal-section#sec-morning
      journal-section#sec-midday
      journal-section#sec-evening
      journal-section#sec-accountability
    journal-log#log