section.day(aria-label="{{entryAriaLabel}}")
  header.day-header
    h2.day-title {{date}}
    .value-challenge(role="group" aria-label="{{focusAriaLabel}}")
      span.value-label(aria-label="{{valueLabelPrefix}}") {{valueLabelPrefix}} {{valueText}}
      span.challenge-label(aria-label="{{challengeLabelPrefix}}") {{challengeLabelPrefix}} {{challengeText}}
  .grid
    .questions(role="region" aria-label="{{questionsAriaLabel}}")
      journal-section#sec-morning
      journal-section#sec-midday
      journal-section#sec-evening
      journal-section#sec-accountability
    journal-section#sec-log